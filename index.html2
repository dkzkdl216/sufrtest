<!DOCTYPE html>
<html lang="ko">

<head>

<meta charset="UTF-8">
<title>Surf Style Test</title>

<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600&display=swap" rel="stylesheet">

<style>

*{
box-sizing:border-box;
font-family:Pretendard, sans-serif;
}

body{

margin:0;

height:100vh;

display:flex;
align-items:center;
justify-content:center;

background:linear-gradient(120deg,#6dd5ed,#2193b0,#7ed8c9);

background-size:400% 400%;
animation:bg 12s ease infinite;

}

@keyframes bg{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.card{

width:420px;

padding:40px;

border-radius:25px;

background:rgba(255,255,255,0.85);

backdrop-filter:blur(12px);

box-shadow:0 25px 60px rgba(0,0,0,0.25);

text-align:center;

}

h1{
margin-top:0;
font-size:32px;
}

h2{
margin-bottom:25px;
}

button{

padding:14px 22px;

border:none;

border-radius:12px;

background:linear-gradient(135deg,#3aa7ff,#6ee7c8);

color:white;

font-size:16px;

margin:8px;

cursor:pointer;

transition:0.25s;

}

button:hover{

transform:translateY(-3px);

box-shadow:0 10px 20px rgba(0,0,0,0.2);

}

.answer{

padding:14px;

margin:10px 0;

border-radius:12px;

background:#f5f8ff;

cursor:pointer;

transition:0.25s;

}

.answer:hover{

background:#e1ecff;

transform:scale(1.03);

}

img{

width:240px;

border-radius:18px;

margin:20px 0;

box-shadow:0 10px 25px rgba(0,0,0,0.15);

}

.progress{

margin-top:18px;

font-size:14px;

color:#777;

}

</style>

</head>


<body>

<div class="card" id="app">

<h1>🏄 Surf Style Test</h1>

<p>언어를 선택하세요<br>Choose Language</p>

<button onclick="start('ko')">한국어</button>
<button onclick="start('en')">English</button>

</div>


<script>

let lang="ko"
let q=0

let score={wave:0,free:0,vibe:0,soul:0}

const applyLink="https://docs.google.com/forms/d/e/1FAIpQLSdUfT1mArajdegkuPpvFVDfW-E7uEoijNLzhviAQCk5fOchiw/viewform"

const data={

ko:{
questions:[

{q:"여행 스타일은?",a:[
{text:"계획적으로 여행",t:"wave"},
{text:"즉흥 여행",t:"free"},
{text:"친구와 여행",t:"vibe"},
{text:"풍경 감상",t:"soul"}]},

{q:"동아리에서 나는?",a:[
{text:"실력 성장",t:"wave"},
{text:"새로운 경험",t:"free"},
{text:"사람들과 친해짐",t:"vibe"},
{text:"힐링",t:"soul"}]},

{q:"바다를 보면?",a:[
{text:"파도 분석",t:"wave"},
{text:"바로 들어감",t:"free"},
{text:"친구 부름",t:"vibe"},
{text:"노을 감상",t:"soul"}]},

{q:"내 성격은?",a:[
{text:"목표지향",t:"wave"},
{text:"모험적",t:"free"},
{text:"사교적",t:"vibe"},
{text:"감성적",t:"soul"}]},

{q:"휴일에 나는?",a:[
{text:"운동",t:"wave"},
{text:"새로운 활동",t:"free"},
{text:"친구 만나기",t:"vibe"},
{text:"산책",t:"soul"}]},

{q:"바다에서 최고의 순간?",a:[
{text:"파도 성공",t:"wave"},
{text:"새 기술 도전",t:"free"},
{text:"같이 웃는 순간",t:"vibe"},
{text:"노을 보는 순간",t:"soul"}]},

{q:"좋아하는 분위기?",a:[
{text:"열정적인",t:"wave"},
{text:"자유로운",t:"free"},
{text:"활기찬",t:"vibe"},
{text:"차분한",t:"soul"}]},

{q:"서핑을 한다면?",a:[
{text:"기술 성장",t:"wave"},
{text:"도전",t:"free"},
{text:"사람들과 즐기기",t:"vibe"},
{text:"자연 감상",t:"soul"}]},

{q:"친구들이 말하는 나는?",a:[
{text:"열심형",t:"wave"},
{text:"모험가",t:"free"},
{text:"분위기메이커",t:"vibe"},
{text:"감성러",t:"soul"}]},

{q:"바다에 가는 이유는?",a:[
{text:"운동",t:"wave"},
{text:"모험",t:"free"},
{text:"친구",t:"vibe"},
{text:"힐링",t:"soul"}]}

],

results:{
wave:{title:"🌊 파도 헌터",desc:"파도를 읽고 도전하는 전략형 서퍼.",img:"wave.png"},
free:{title:"🏄 자유 서퍼",desc:"자유롭고 모험을 즐기는 타입.",img:"free.png"},
vibe:{title:"🌴 비치 바이브",desc:"사람들과 있을 때 가장 빛나는 분위기 메이커.",img:"vibe.png"},
soul:{title:"🌅 오션 소울",desc:"바다 감성을 깊이 느끼는 힐링형.",img:"soul.png"}
}

},

en:{
questions:[
{q:"Your travel style?",a:[
{text:"Planned trip",t:"wave"},
{text:"Spontaneous",t:"free"},
{text:"With friends",t:"vibe"},
{text:"Enjoy scenery",t:"soul"}]}
],

results:{
wave:{title:"🌊 Wave Hunter",desc:"Strategic surfer chasing waves.",img:"wave.png"},
free:{title:"🏄 Free Surfer",desc:"Adventure lover exploring waves.",img:"free.png"},
vibe:{title:"🌴 Beach Vibe Maker",desc:"Social energy of the beach.",img:"vibe.png"},
soul:{title:"🌅 Ocean Soul",desc:"Deeply connected to the ocean.",img:"soul.png"}
}

}

}


function start(l){

lang=l
q=0
score={wave:0,free:0,vibe:0,soul:0}

next()

}


function next(){

let question=data[lang].questions[q]

let html=`<h2>${question.q}</h2>`

question.a.forEach(a=>{
html+=`<div class="answer" onclick="select('${a.t}')">${a.text}</div>`
})

html+=`<p class="progress">${q+1}/10</p>`

document.getElementById("app").innerHTML=html

}


function select(type){

score[type]++

q++

if(q<10){

next()

}else{

showResult()

}

}


function showResult(){

let max=Object.keys(score).reduce((a,b)=>score[a]>score[b]?a:b)

let r=data[lang].results[max]

let text=lang==="ko"?"동아리 신청하기":"Apply for the Club"

document.getElementById("app").innerHTML=`

<h2>${r.title}</h2>

<img src="${r.img}">

<p>${r.desc}</p>

<a href="${applyLink}" target="_blank">

<button>${text}</button>

</a>

`

}

</script>

</body>
</html>
